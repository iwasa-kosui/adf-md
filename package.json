{
  "name": "adf-md",
  "version": "0.2.0",
  "description": "Bidirectional converter between Atlassian Document Format (ADF) and Markdown",
  "keywords": [
    "adf",
    "markdown",
    "atlassian",
    "jira",
    "confluence",
    "converter"
  ],
  "license": "MIT",
  "author": "Kosui Iwasa",
  "repository": {
    "type": "git",
    "url": "https://github.com/iwasa-kosui/adf-md.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mdast": "^4.0.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@praha/byethrow": "^0.10.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5"
  }
}
